---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { categories, getImagesForCategory } from "../../data/categories";
import lqipData from "../../data/lqip.json";
import imageManifest from "../../data/image-manifest.json";
import type { GetStaticPaths } from "astro";


export const getStaticPaths: GetStaticPaths = () => {
  return categories.map((cat) => ({
    params: { category: cat.slug },
    props: { category: cat },
  }));
};

const { category } = Astro.props;
const images = getImagesForCategory(category);

const categoryIndex = categories.findIndex(c => c.slug === category.slug);
const prevCategory = categories[categoryIndex - 1] ?? null;
const nextCategory = categories[categoryIndex + 1] ?? null;

// Distribute images across 3 columns for the scroll effect
const columns: string[][] = [[], [], []];
images.forEach((src, i) => {
  columns[i % 3].push(src);
});
---

<BaseLayout
  title={`${category.name} — Gavin Batty`}
  description={category.description}
  ogImage={category.cover}
  showFooter={false}
>
  <section class="columns-wrap">
    <header class="gallery-hero">
      <h1 transition:name="gallery-title">{category.name}</h1>
      <p class="gallery-hero__desc" transition:name="gallery-desc">{category.description}</p>
    </header>
    <div class="columns" data-columns>
      {columns.map((col, colIndex) => (
        <div class="column" data-col={colIndex}>
          {col.map((src, imgIndex) => {
            const globalIndex = imgIndex * 3 + colIndex;
            const isAboveFold = globalIndex < 6;
            return (
              <button
                class="column__item"
                data-index={globalIndex}
                data-src={src}
                aria-label={`View ${category.name} photo ${globalIndex + 1}`}
              >
                <div
                  class="column__item-imgwrap"
                  style={[
                    lqipData[src as keyof typeof lqipData] ? `background-image:url(${lqipData[src as keyof typeof lqipData]})` : '',
                    imageManifest[src as keyof typeof imageManifest] ? `aspect-ratio:${imageManifest[src as keyof typeof imageManifest].width}/${imageManifest[src as keyof typeof imageManifest].height}` : '',
                  ].filter(Boolean).join(';') || undefined}
                >
                  <picture>
                    {imageManifest[src as keyof typeof imageManifest]?.webp && (
                      <source
                        srcset={imageManifest[src as keyof typeof imageManifest].webp}
                        type="image/webp"
                      />
                    )}
                    <img
                      src={src}
                      alt={`${category.name} photo ${globalIndex + 1}`}
                      width={imageManifest[src as keyof typeof imageManifest]?.width}
                      height={imageManifest[src as keyof typeof imageManifest]?.height}
                      loading={isAboveFold ? "eager" : "lazy"}
                      decoding="async"
                      class="column__item-img"
                    />
                  </picture>
                </div>
              </button>
            );
          })}
        </div>
      ))}
    </div>

  </section>

  <!-- Gallery eye cursor — appears on desktop over images (outside columns-wrap to avoid overflow clip) -->
  <div class="gallery-cursor" id="gallery-cursor">
    <svg class="gallery-cursor__eye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
      <circle cx="12" cy="12" r="3"/>
    </svg>
  </div>

  <!-- Bottom navigation bar — slides up on scroll -->
  <nav class="cat-bar" id="cat-bar" aria-label="Gallery navigation">
    <!-- Category menu drawer -->
    <div class="cat-bar__menu" id="cat-menu">
      <ul class="cat-bar__menu-list">
        {categories.map((cat) => (
          <li>
            <a
              href={`/gallery/${cat.slug}`}
              class:list={["cat-bar__menu-link", { "cat-bar__menu-link--active": cat.slug === category.slug }]}
            >
              {cat.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
    <!-- Main bar -->
    <div class="cat-bar__inner">
      <button class="cat-bar__title" id="cat-menu-toggle" aria-label="Browse all categories" aria-expanded="false">
        <svg class="cat-bar__burger" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="8" x2="20" y2="8"/>
          <line x1="4" y1="16" x2="20" y2="16"/>
        </svg>
        <span>{category.name}</span>
      </button>
      <button class="cat-bar__top" id="back-to-top" aria-label="Back to top">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
        <span>Top</span>
      </button>
    </div>
  </nav>

  <!-- Bottom category pagination -->
  <nav class="gallery-end" aria-label="End of gallery">
    <a href="/" class="gallery-end__home">
      <svg class="gallery-end__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 17L7 7M7 7H17M7 7V17"/>
      </svg>
      <span>Home</span>
    </a>
  </nav>

  <!-- Lightbox -->
  <script is:inline define:vars={{ lqipData }}>
    window.__lqip = lqipData;
  </script>
  <div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-label="Image viewer">
    <div class="lightbox__image-wrap">
      <img class="lightbox__img" src="" alt="" />
      <img class="lightbox__img lightbox__img--staging" src="" alt="" aria-hidden="true" />
      <button class="lightbox__zone lightbox__zone--prev" aria-label="Previous image"></button>
      <button class="lightbox__zone lightbox__zone--next" aria-label="Next image"></button>
      <div class="lb-cursor" id="lb-cursor">
        <svg class="lb-cursor__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M5 12L12 19M5 12L12 5"/>
        </svg>
      </div>
    </div>
    <div class="lightbox__toolbar" id="lb-toolbar">
      <div class="lightbox__toolbar-inner">
        <div class="lightbox__tb-nav">
          <button class="lightbox__tb-btn lightbox__prev" aria-label="Previous image">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <div class="lightbox__tb-center">
            <span class="lightbox__counter"></span>
            <span class="lightbox__hint">Swipe · Double-tap to zoom</span>
          </div>
          <button class="lightbox__tb-btn lightbox__next" aria-label="Next image">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
        <button class="lightbox__tb-btn lightbox__close" aria-label="Close lightbox">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>
  </div>
</BaseLayout>

<style>

  /* Hero — inside columns-wrap, flows into grid */
  .gallery-hero {
    padding: calc(var(--nav-height, 80px) + var(--space-xl)) var(--space-md) var(--space-lg);
    text-align: center;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  @media (max-width: 600px) {
    .gallery-hero {
      padding-top: calc(var(--nav-height, 70px) + 1rem);
    }
  }

  /* End of gallery — bold Home link */
  .gallery-end {
    display: flex;
    justify-content: center;
    padding: 3rem var(--space-md);
    padding-bottom: calc(3rem + 56px); /* clear the fixed bottom bar */
  }

  .gallery-end__home {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-heading);
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    padding: 0.8rem 1.6rem;
    border: 1px solid var(--color-text);
    border-radius: 100px;
    transition: background-color 0.25s, color 0.25s, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-end__home:hover {
    background-color: var(--color-text);
    color: var(--color-text-light);
  }

  .gallery-end__home:hover .gallery-end__icon {
    transform: translate(-2px, -2px);
  }

  .gallery-end__icon {
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-end__home span {
    translate: 0 0.08em;
  }

  /* Entrance animation */
  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .gallery-hero h1 {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 400;
    margin-bottom: var(--space-xs);
    letter-spacing: -0.03em;
    opacity: 0;
    animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }

  .gallery-hero__desc {
    font-family: var(--font-heading);
    font-style: italic;
    color: var(--color-text-muted);
    font-size: 1.15rem;
    margin: 0 auto;
    text-align: center;
    opacity: 0;
    animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.25s forwards;
  }


  /* ── Bottom category bar ── */
  .cat-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 202;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .cat-bar.visible {
    transform: translateY(0);
    pointer-events: auto;
  }

  .cat-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.7rem var(--space-md);
    padding-bottom: calc(0.7rem + env(safe-area-inset-bottom, 0px));
    background: rgba(245, 244, 240, 0.95);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .cat-bar__title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    min-width: 6rem;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    transition: background-color 0.2s;
  }

  .cat-bar__title:hover {
    background-color: rgba(0, 0, 0, 0.05);
  }

  .cat-bar__burger {
    opacity: 0.5;
    transition: opacity 0.2s, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cat-bar__title:hover .cat-bar__burger {
    opacity: 0.8;
  }

  .cat-bar.menu-open .cat-bar__burger {
    transform: rotate(90deg);
    opacity: 0.8;
  }

  .cat-bar__top {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    background: none;
    border: none;
    font-family: var(--font-body);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 0.3rem 0.5rem;
    border-radius: 6px;
    transition: color 0.2s, background-color 0.2s;
  }

  .cat-bar__top span {
    translate: 0 0.1em;
  }

  .cat-bar__top:hover {
    color: var(--color-text);
    background-color: rgba(0, 0, 0, 0.05);
  }

  /* ── Category menu drawer ── */
  .cat-bar__menu {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    background: rgba(245, 244, 240, 0.98);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .cat-bar.menu-open .cat-bar__menu {
    max-height: 400px;
  }

  .cat-bar__menu-list {
    list-style: none;
    margin: 0;
    padding: 1.2rem var(--space-md) 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .cat-bar__menu-link {
    display: block;
    padding: 0.6rem 0.8rem;
    font-family: var(--font-heading);
    font-size: 1rem;
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.2s, background-color 0.2s;
  }

  .cat-bar__menu-link:hover {
    color: var(--color-text);
    background-color: rgba(0, 0, 0, 0.04);
  }

  .cat-bar__menu-link--active {
    color: var(--color-text);
    font-weight: 500;
    background-color: rgba(0, 0, 0, 0.04);
  }


  /* ===== Columns with scroll animation ===== */
  .columns-wrap {
    overflow: hidden;
    padding-bottom: var(--space-lg);
  }

  .columns {
    display: flex;
    gap: var(--space-sm);
    padding: 0 var(--space-md);
    max-width: var(--max-width);
    margin: 0 auto;
    will-change: transform;
    opacity: 0;
    animation: fadeSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
  }

  .column {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    will-change: transform;
  }

  /* Offset middle column for visual interest */
  .column[data-col="1"] {
    margin-top: 8vh;
  }

  .column__item {
    display: block;
    width: 100%;
    overflow: hidden;
    border-radius: 6px;
    cursor: pointer;
    position: relative;
  }

  .column__item-imgwrap {
    overflow: hidden;
    border-radius: 6px;
    position: relative;
    /* Ensure border-radius clips even when column is on its own GPU layer */
    transform: translateZ(0);
    /* LQIP: tiny base64 thumbnail as background, visible until real image loads */
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .column__item-imgwrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: inherit;
    background-size: cover;
    background-position: center;
    filter: blur(15px);
    transform: scale(1.1);
    transition: opacity 0.4s ease;
  }

  .column__item-imgwrap.revealed::after {
    opacity: 0;
  }

  .column__item-img {
    width: 100%;
    display: block;
    position: relative;
    z-index: 1;
    opacity: 0;
    transition: opacity 0.35s ease, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  .column__item-img.loaded {
    opacity: 1;
  }

  .column__item:hover .column__item-img {
    transform: scale(1.05);
  }

  /* Gallery eye cursor — desktop only */
  .gallery-cursor {
    display: none;
  }

  @media (min-width: 769px) {
    .gallery-cursor {
      display: flex;
      align-items: center;
      justify-content: center;
      position: fixed;
      top: 0;
      left: 0;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: #fff;
      pointer-events: none;
      z-index: 50;
      transform: translate(-50%, -50%) scale(0);
      opacity: 0;
      will-change: transform;
      mix-blend-mode: difference;
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                  opacity 0.15s ease;
      color: #000;
    }

    .gallery-cursor.visible {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
    }

    .gallery-cursor__eye {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
    }

    /* Hide default cursor over gallery images when custom cursor active */
    .columns-wrap.cursor-active {
      cursor: none;
    }

    .columns-wrap.cursor-active .column__item,
    .columns-wrap.cursor-active .column__item * {
      cursor: none;
    }
  }

  @media (max-width: 768px) {
    .columns {
      gap: 0.75rem;
      padding: 0 1rem;
    }

    .column[data-col="1"] {
      margin-top: 4vh;
    }
  }

  @media (max-width: 500px) {
    .columns {
      flex-direction: column;
      gap: 0.5rem;
      padding: 0 1rem;
    }

    .column {
      flex: none;
      width: 100%;
      gap: 0.5rem;
    }

    .column[data-col="1"] {
      margin-top: 0;
    }
  }

  /* ===== Lightbox ===== */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 300;
    background: #000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    -webkit-user-select: none;
    user-select: none;
  }

  .lightbox.active {
    opacity: 1;
    pointer-events: all;
  }

  .lightbox__image-wrap {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    touch-action: none;
  }

  .lightbox__img {
    max-width: 92vw;
    max-height: 85vh;
    object-fit: contain;
    transform-origin: center center;
    will-change: transform;
    flex-shrink: 0;
  }

  .lightbox__img--staging {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0;
    pointer-events: none;
  }

  /* Desktop click zones — invisible prev/next areas on left/right 20% */
  .lightbox__zone {
    display: none;
  }

  @media (min-width: 601px) {
    .lightbox__zone {
      display: block;
      position: absolute;
      top: 0;
      bottom: 0;
      width: 20%;
      z-index: 5;
      background: none;
      border: none;
      padding: 0;
      opacity: 0;
      cursor: none;
    }

    .lightbox__zone--prev {
      left: 0;
    }

    .lightbox__zone--next {
      right: 0;
    }
  }

  /* Lightbox custom cursor — reuses carousel dot style */
  .lb-cursor {
    display: none;
  }

  @media (min-width: 601px) {
    .lb-cursor {
      display: flex;
      align-items: center;
      justify-content: center;
      position: fixed;
      top: 0;
      left: 0;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: #fff;
      pointer-events: none;
      z-index: 320;
      transform: translate(-50%, -50%) scale(0);
      opacity: 0;
      will-change: transform;
      mix-blend-mode: difference;
      transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                  height 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                  opacity 0.15s ease;
      overflow: hidden;
      color: #000;
    }

    .lb-cursor.visible {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
    }

    .lb-cursor__arrow {
      width: 18px;
      height: 18px;
      opacity: 0;
      transform: rotate(45deg);
      transition: opacity 0.2s ease, transform 0.2s ease;
      flex-shrink: 0;
    }

    .lb-cursor.arrow-left,
    .lb-cursor.arrow-right {
      width: 44px;
      height: 44px;
    }

    .lb-cursor.arrow-left .lb-cursor__arrow {
      opacity: 1;
      transform: rotate(0deg);
    }

    .lb-cursor.arrow-right .lb-cursor__arrow {
      opacity: 1;
      transform: rotate(180deg);
    }

    /* Hide default cursor over lightbox when custom cursor active */
    .lightbox.cursor-active {
      cursor: none;
    }

    .lightbox.cursor-active .lightbox__image-wrap,
    .lightbox.cursor-active .lightbox__img,
    .lightbox.cursor-active .lightbox__toolbar {
      cursor: none;
    }
  }

  /* ── Toolbar ── */
  .lightbox__toolbar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 10;
    padding-bottom: env(safe-area-inset-bottom, 0px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }


  .lightbox__toolbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.5rem;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .lightbox__tb-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .lightbox__tb-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.2s, background-color 0.2s;
    flex-shrink: 0;
  }

  .lightbox__tb-btn:hover {
    color: #fff;
    background-color: rgba(255, 255, 255, 0.1);
  }


  .lightbox__tb-center {
    position: relative;
    min-width: 7rem;
    text-align: center;
    height: 1.2em;
  }

  .lightbox__counter,
  .lightbox__hint {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    white-space: nowrap;
    transition: opacity 0.4s ease;
  }

  .lightbox__hint {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.4);
    opacity: 0;
    pointer-events: none;
  }

  .lightbox__hint.visible {
    opacity: 1;
  }

  .lightbox__hint.visible + .lightbox__counter,
  .lightbox__counter.hint-hidden {
    opacity: 0;
  }

  @media (max-width: 600px) {
    .lightbox__img {
      max-width: 100vw;
    }

    .lightbox__toolbar-inner {
      padding: 0.75rem 1rem;
    }
  }
</style>

<script>
  import "../../scripts/gallery";
</script>
