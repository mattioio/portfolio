---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { categories, getImagesForCategory } from "../../data/categories";
import lqipData from "../../data/lqip.json";
import imageManifest from "../../data/image-manifest.json";
import type { GetStaticPaths } from "astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

export const getStaticPaths: GetStaticPaths = () => {
  return categories.map((cat) => ({
    params: { category: cat.slug },
    props: { category: cat },
  }));
};

const { category } = Astro.props;
const images = getImagesForCategory(category);

const categoryIndex = categories.findIndex(c => c.slug === category.slug);
const prevCategory = categories[categoryIndex - 1] ?? null;
const nextCategory = categories[categoryIndex + 1] ?? null;

// Distribute images across 3 columns for the scroll effect
const columns: string[][] = [[], [], []];
images.forEach((src, i) => {
  columns[i % 3].push(src);
});
---

<BaseLayout
  title={`${category.name} — Gavin Batty`}
  description={category.description}
  ogImage={category.cover}
  showFooter={false}
>
  <section class="gallery-hero">
    <div class="container">
      <h1 transition:name="gallery-title">{category.name}</h1>
      <p class="gallery-hero__desc" transition:name="gallery-desc">{category.description}</p>
    </div>
  </section>

  <section class="columns-wrap">
    <div class="columns" data-columns>
      {columns.map((col, colIndex) => (
        <div class="column" data-col={colIndex}>
          {col.map((src, imgIndex) => {
            const globalIndex = imgIndex * 3 + colIndex;
            const isAboveFold = globalIndex < 6;
            return (
              <button
                class="column__item"
                data-index={globalIndex}
                data-src={`${base}${src}`}
                aria-label={`View ${category.name} photo ${globalIndex + 1}`}
              >
                <div
                  class="column__item-imgwrap"
                  style={[
                    lqipData[src as keyof typeof lqipData] ? `background-image:url(${lqipData[src as keyof typeof lqipData]})` : '',
                    imageManifest[src as keyof typeof imageManifest] ? `aspect-ratio:${imageManifest[src as keyof typeof imageManifest].width}/${imageManifest[src as keyof typeof imageManifest].height}` : '',
                  ].filter(Boolean).join(';') || undefined}
                >
                  <picture>
                    {imageManifest[src as keyof typeof imageManifest]?.webp && (
                      <source
                        srcset={`${base}${imageManifest[src as keyof typeof imageManifest].webp}`}
                        type="image/webp"
                      />
                    )}
                    <img
                      src={`${base}${src}`}
                      alt={`${category.name} photo ${globalIndex + 1}`}
                      width={imageManifest[src as keyof typeof imageManifest]?.width}
                      height={imageManifest[src as keyof typeof imageManifest]?.height}
                      loading={isAboveFold ? "eager" : "lazy"}
                      decoding="async"
                      class="column__item-img"
                    />
                  </picture>
                </div>
              </button>
            );
          })}
        </div>
      ))}
    </div>
  </section>

  <!-- Sticky category bar — appears on scroll -->
  <nav class="cat-bar" id="cat-bar" aria-label="Gallery navigation">
    <div class="cat-bar__inner">
      {prevCategory
        ? <a href={`${base}/gallery/${prevCategory.slug}`} class="cat-bar__arrow" aria-label={`Previous: ${prevCategory.name}`}>
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </a>
        : <span class="cat-bar__arrow cat-bar__arrow--disabled"></span>
      }
      <span class="cat-bar__title">{category.name}</span>
      {nextCategory
        ? <a href={`${base}/gallery/${nextCategory.slug}`} class="cat-bar__arrow" aria-label={`Next: ${nextCategory.name}`}>
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        : <span class="cat-bar__arrow cat-bar__arrow--disabled"></span>
      }
      <button class="cat-bar__top" id="back-to-top" aria-label="Back to top">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
      </button>
    </div>
  </nav>

  <!-- Bottom category pagination -->
  <nav class="cat-pagination cat-pagination--bottom" aria-label="Browse categories">
    {prevCategory
      ? <a href={`${base}/gallery/${prevCategory.slug}`} class="cat-pagination__arrow cat-pagination__arrow--prev" aria-label={`Previous: ${prevCategory.name}`}>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          <span>{prevCategory.name}</span>
        </a>
      : <span class="cat-pagination__arrow cat-pagination__arrow--prev cat-pagination__arrow--disabled"></span>
    }
    <a href={`${base}/`} class="gallery-back">
      <svg class="gallery-back__arrow" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 17L7 7M7 7H17M7 7V17"/>
      </svg>
      <span>Close</span>
    </a>
    {nextCategory
      ? <a href={`${base}/gallery/${nextCategory.slug}`} class="cat-pagination__arrow cat-pagination__arrow--next" aria-label={`Next: ${nextCategory.name}`}>
          <span>{nextCategory.name}</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      : <span class="cat-pagination__arrow cat-pagination__arrow--next cat-pagination__arrow--disabled"></span>
    }
  </nav>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-label="Image viewer">
    <button class="lightbox__close" aria-label="Close">&times;</button>
    <button class="lightbox__prev" aria-label="Previous image">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="lightbox__next" aria-label="Next image">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <div class="lightbox__image-wrap">
      <img class="lightbox__img" src="" alt="" />
    </div>
    <div class="lightbox__counter"></div>
    <div class="lightbox__swipe-hint" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
      <span>Swipe to navigate</span>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </div>
  </div>
</BaseLayout>

<style>

  /* Hero */
  .gallery-hero {
    padding: calc(var(--nav-height, 80px) + var(--space-xl)) 0 var(--space-lg);
    text-align: center;
  }

  @media (max-width: 600px) {
    .gallery-hero {
      padding-top: calc(var(--nav-height, 70px) + 1rem);
    }
  }

  /* Bottom pagination: always visible */
  .cat-pagination--bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2rem var(--space-md);
    max-width: var(--max-width);
    margin: 0 auto;
    border-top: 1px solid rgba(0,0,0,0.08);
  }

  .cat-pagination__arrow {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    text-decoration: none;
    min-width: 5rem;
    transition: color 0.2s;
  }

  .cat-pagination__arrow--next {
    justify-content: flex-end;
  }

  .cat-pagination__arrow--disabled {
    pointer-events: none;
    opacity: 0;
  }

  .cat-pagination__arrow:not(.cat-pagination__arrow--disabled):hover {
    color: var(--color-text);
  }

  .gallery-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
    text-decoration: none;
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 100px;
    padding: 0.5rem 1rem 0.5rem 0.75rem;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .gallery-back__arrow {
    flex-shrink: 0;
    width: 14px;
    height: 14px;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cat-pagination__arrow span {
    translate: 0 0.2em;
  }

  .gallery-back span {
    translate: 0 0.15em;
  }

  .gallery-back:hover {
    background: rgba(0, 0, 0, 0.08);
    border-color: rgba(0, 0, 0, 0.15);
    color: var(--color-text);
  }

  .gallery-back:hover .gallery-back__arrow {
    transform: translate(-2px, -2px);
  }

  .gallery-hero h1 {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 400;
    margin-bottom: var(--space-xs);
    letter-spacing: -0.03em;
  }

  .gallery-hero__desc {
    font-family: var(--font-heading);
    font-style: italic;
    color: var(--color-text-muted);
    font-size: 1.15rem;
    margin: 0 auto;
    text-align: center;
  }

  /* ── Sticky category bar ── */
  .cat-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 202;
    transform: translateY(-100%);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .cat-bar.visible {
    transform: translateY(0);
    pointer-events: auto;
  }

  .cat-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 0.6rem var(--space-md);
    background: rgba(245, 244, 240, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .cat-bar__title {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    min-width: 6rem;
    text-align: center;
  }

  .cat-bar__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    color: var(--color-text-muted);
    transition: color 0.2s, background-color 0.2s;
  }

  .cat-bar__arrow:hover {
    color: var(--color-text);
    background-color: rgba(0, 0, 0, 0.05);
  }

  .cat-bar__arrow--disabled {
    opacity: 0;
    pointer-events: none;
    width: 32px;
  }

  .cat-bar__top {
    position: absolute;
    right: var(--space-md);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    color: var(--color-text-muted);
    transition: color 0.2s, background-color 0.2s;
  }

  .cat-bar__top:hover {
    color: var(--color-text);
    background-color: rgba(0, 0, 0, 0.05);
  }

  /* ===== Columns with scroll animation ===== */
  .columns-wrap {
    overflow: hidden;
    padding-bottom: var(--space-xl);
  }

  .columns {
    display: flex;
    gap: var(--space-sm);
    padding: 0 var(--space-md);
    max-width: var(--max-width);
    margin: 0 auto;
    will-change: transform;
  }

  .column {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    will-change: transform;
  }

  /* Offset middle column for visual interest */
  .column[data-col="1"] {
    margin-top: 8vh;
  }

  .column__item {
    display: block;
    width: 100%;
    overflow: hidden;
    border-radius: 6px;
    cursor: pointer;
    position: relative;
  }

  .column__item-imgwrap {
    overflow: hidden;
    border-radius: 6px;
    position: relative;
    /* Ensure border-radius clips even when column is on its own GPU layer */
    transform: translateZ(0);
    /* LQIP: tiny base64 thumbnail as background, visible until real image loads */
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .column__item-img {
    width: 100%;
    display: block;
    opacity: 0;
    transition: opacity 0.35s ease, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  .column__item-img.loaded {
    opacity: 1;
  }

  .column__item:hover .column__item-img {
    transform: scale(1.05);
  }

  @media (max-width: 768px) {
    .columns {
      gap: 0.75rem;
      padding: 0 1rem;
    }

    .column[data-col="1"] {
      margin-top: 4vh;
    }
  }

  @media (max-width: 500px) {
    .columns {
      flex-direction: column;
      gap: 0.5rem;
      padding: 0 1rem;
    }

    .column {
      flex: none;
      width: 100%;
      gap: 0.5rem;
    }

    .column[data-col="1"] {
      margin-top: 0;
    }
  }

  /* ===== Lightbox ===== */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    -webkit-user-select: none;
    user-select: none;
  }

  .lightbox.active {
    opacity: 1;
    pointer-events: all;
  }

  .lightbox__close {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    color: white;
    font-size: 2rem;
    z-index: 10;
    opacity: 0.7;
    transition: opacity 0.2s;
    line-height: 1;
  }

  .lightbox__close:hover { opacity: 1; }

  .lightbox__prev,
  .lightbox__next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    color: white;
    z-index: 10;
    padding: var(--space-sm);
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .lightbox__prev:hover,
  .lightbox__next:hover { opacity: 1; }

  .lightbox__prev { left: var(--space-sm); }
  .lightbox__next { right: var(--space-sm); }

  .lightbox__image-wrap {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    touch-action: none; /* We handle pinch/pan ourselves */
  }

  .lightbox__img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    transition: opacity 0.2s;
    transform-origin: center center;
    will-change: transform;
  }

  .lightbox__counter {
    position: absolute;
    bottom: var(--space-md);
    left: 50%;
    transform: translateX(-50%);
    color: white;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    opacity: 0.5;
  }

  /* Swipe hint — mobile only, first open */
  .lightbox__swipe-hint {
    display: none;
  }

  @media (max-width: 600px) {
    .lightbox__swipe-hint {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: white;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      opacity: 0;
      pointer-events: none;
      z-index: 15;
      transition: opacity 0.4s ease;
    }

    .lightbox__swipe-hint.visible {
      opacity: 0.7;
    }

    .lightbox__swipe-hint svg:first-child {
      animation: hint-left 1.2s ease-in-out infinite;
    }

    .lightbox__swipe-hint svg:last-child {
      animation: hint-right 1.2s ease-in-out infinite;
    }

    @keyframes hint-left {
      0%, 100% { transform: translateX(0); }
      50% { transform: translateX(-6px); }
    }

    @keyframes hint-right {
      0%, 100% { transform: translateX(0); }
      50% { transform: translateX(6px); }
    }
  }

  /* Mobile: bigger images, hide desktop nav arrows, use swipe */
  @media (max-width: 600px) {
    .lightbox__prev,
    .lightbox__next {
      display: none;
    }

    .lightbox__img {
      max-width: 100vw;
      max-height: 100vh;
    }

    .lightbox__close {
      top: 0.75rem;
      right: 0.75rem;
      font-size: 2.5rem;
      padding: 0.5rem;
      z-index: 20;
    }

    .lightbox__counter {
      bottom: 1rem;
    }
  }
</style>

<script>
  import "../../scripts/gallery";
</script>
