---
import BaseLayout from "../layouts/BaseLayout.astro";
import { dayRate, services } from "../data/services";
---

<BaseLayout title="Services — Gavin Batty" description="Photography packages and day rates for weddings, music, food & hospitality, and sport.">
  <section class="services-hero">
    <div class="container">
      <h1>Services</h1>
      <p class="services-hero__sub">Professional photography tailored to your vision</p>
    </div>
  </section>

  <section class="day-rate">
    <div class="container">
      <div class="day-rate__card">
        <span class="day-rate__label">{dayRate.label}</span>
        <h2 class="day-rate__price">{dayRate.price}</h2>
        <p class="day-rate__note">{dayRate.note}</p>
      </div>
    </div>
  </section>

  <section class="specialties">
    <div class="container">
      <h2 class="specialties__heading">Specialties</h2>
      <div class="specialties__grid">
        {services.map((service) => (
          <div class="service-card">
            <div class="service-card__header">
              <h3>{service.title}</h3>
              <p class="service-card__note">{service.note}</p>
            </div>
            <ul class="service-card__list">
              {service.includes.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            <a href={`/gallery/${service.slug}`} class="service-card__link">
              View {service.title} work &rarr;
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="services-cta">
    <div class="container">
      <div class="services-cta__inner">
        <h2>Let's create something together</h2>
        <p>Every project is unique. Get in touch to discuss your vision and receive a custom quote.</p>
        <a href="mailto:hello@gavinbatty.com" class="services-cta__btn">Get in Touch</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .services-hero {
    padding: calc(var(--nav-height) + var(--space-xl)) 0 var(--space-lg);
    text-align: center;
  }

  .services-hero__sub {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin-top: var(--space-xs);
  }

  /* Day Rate */
  .day-rate {
    padding: var(--space-lg) 0;
  }

  .day-rate__card {
    text-align: center;
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    max-width: 600px;
    margin: 0 auto;
  }

  .day-rate__label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
  }

  .day-rate__price {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    margin: var(--space-xs) 0;
  }

  .day-rate__note {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    max-width: 45ch;
    margin: 0 auto;
  }

  /* Specialties */
  .specialties {
    padding: var(--space-lg) 0 var(--space-xl);
  }

  .specialties__heading {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .specialties__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  .service-card {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s;
  }

  .service-card:hover {
    border-color: var(--color-text);
  }

  .service-card h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    margin-bottom: var(--space-xs);
  }

  .service-card__note {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: var(--space-md);
  }

  .service-card__list {
    flex: 1;
    margin-bottom: var(--space-md);
  }

  .service-card__list li {
    padding: 0.4rem 0;
    padding-left: 1.25rem;
    position: relative;
    font-size: 0.9rem;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
  }

  .service-card__list li:last-child {
    border-bottom: none;
  }

  .service-card__list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    transform: translateY(-50%);
  }

  .service-card__link {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.6;
    transition: opacity 0.2s;
    align-self: flex-start;
  }

  .service-card__link:hover {
    opacity: 1;
  }

  /* CTA */
  .services-cta {
    padding: var(--space-xl) 0;
    background: var(--color-bg-dark);
    color: var(--color-text-light);
    text-align: center;
  }

  .services-cta__inner {
    max-width: 550px;
    margin: 0 auto;
  }

  .services-cta h2 {
    color: #fff;
    margin-bottom: var(--space-sm);
  }

  .services-cta p {
    color: var(--color-text-muted);
    margin: 0 auto var(--space-md);
  }

  .services-cta__btn {
    display: inline-block;
    padding: 0.875rem 2.5rem;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    transition: background-color 0.3s, color 0.3s;
  }

  .services-cta__btn:hover {
    background: var(--color-accent);
    color: var(--color-bg-dark);
  }

  @media (max-width: 768px) {
    .specialties__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
