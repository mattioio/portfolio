---
import BaseLayout from "../layouts/BaseLayout.astro";
import ScrollCarousel from "../components/ScrollCarousel.astro";
import { Image } from "astro:assets";
import profilePic from "../assets/profile-pic.jpg";
---

<BaseLayout title="Gavin Batty — Photographer">
  <ScrollCarousel />

  <!-- Intro section: fixed behind hero, revealed as hero scrolls away -->
  <section class="reveal-section">
    <div class="reveal-section__sticky">
      <section class="intro">
        <div class="container">
          <div class="intro__content">
            <Image src={profilePic} alt="Gavin Batty" class="intro__portrait" width={440} quality={80} format="webp" loading="lazy" />
            <h2 class="intro__title" data-blur-reveal>Capturing moments that <em>matter.</em></h2>
            <p class="intro__sub" data-blur-reveal>From wedding days to <em>stadium lights,</em> restaurant tables to <em>mountain peaks.</em></p>
            <button class="btn btn--dark intro__cta" id="open-services" data-blur-reveal>
              View Services
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M7 17L17 7M17 7H7M17 7V17" />
              </svg>
            </button>
          </div>
        </div>
      </section>
    </div>
  </section>

</BaseLayout>

<style>
  /* ===== Reveal section ===== */
  .reveal-section {
    position: relative;
    height: auto;
    background: transparent;
    z-index: 3;
    margin-top: -50vh;
    pointer-events: none;
  }

  .reveal-section__sticky {
    --card-margin: var(--space-sm);
    --card-radius: 20px;
    background: var(--color-bg);
    border-radius: var(--card-radius) var(--card-radius) 0 0;
    overflow: hidden;
    pointer-events: auto;
    padding: 4vh 0 2vh;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 8vh;
    margin-left: var(--card-margin);
    margin-right: var(--card-margin);
    margin-bottom: 0;
  }

  .intro {
    padding: var(--space-xl) 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    width: 100%;
  }

  .intro__content {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .intro__portrait {
    width: 220px;
    height: 220px;
    clip-path: inset(0% round 16%);
    object-fit: cover;
    margin: 0 auto var(--space-md);
    display: block;
    border: 2px solid var(--color-border, rgba(0,0,0,0.08));
    will-change: transform, clip-path;
    transform-origin: center center;
  }

  .intro__title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    max-width: 18ch;
    margin-left: auto;
    margin-right: auto;
    letter-spacing: -0.02em;
  }

  .intro__title em { font-style: italic; }

  .intro__sub {
    font-family: var(--font-heading);
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-muted, #999);
    margin-bottom: var(--space-lg);
    letter-spacing: -0.01em;
    max-width: 32ch;
    margin-left: auto;
    margin-right: auto;
  }

  .intro__sub em {
    font-style: italic;
    color: var(--color-text-muted, #888);
  }

  .intro__cta {
    font-size: 0.875rem;
    padding: 0.75rem 2rem 0.75rem calc(2rem + 0.15em);
  }

  .intro__cta svg {
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .intro__cta:hover svg {
    transform: translate(2px, -2px);
  }

  [data-blur-reveal] .char { display: inline-block; }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    if (!document.querySelector('.reveal-section')) return;

    // ===== Services panel =====
    const openBtn = document.getElementById('open-services');
    const panel = document.getElementById('services-panel');
    if (openBtn && panel) {
      openBtn.addEventListener('click', () => {
        panel.classList.add('active');
        panel.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      });
    }

    // ===== Blur-reveal animation (Codrops ScrollBlurTypography #1) =====
    // Split text nodes into individual <span class="char"> elements
    function splitIntoChars(el: Element) {
      const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null);
      const textNodes: Text[] = [];
      let node: Text | null;
      while ((node = walker.nextNode() as Text)) {
        if (node.textContent) textNodes.push(node);
      }
      textNodes.forEach(textNode => {
        const text = textNode.textContent!;
        const frag = document.createDocumentFragment();
        for (let i = 0; i < text.length; i++) {
          const ch = text[i];
          if (ch === ' ' || ch === '\n' || ch === '\t') {
            frag.appendChild(document.createTextNode(ch));
          } else {
            const span = document.createElement('span');
            span.className = 'char';
            span.textContent = ch;
            frag.appendChild(span);
          }
        }
        textNode.parentNode?.replaceChild(frag, textNode);
      });
    }

    // Build per-element animation groups — each [data-blur-reveal] is its own scroll trigger
    const groups: { el: Element; chars: HTMLElement[]; isButton: boolean }[] = [];

    document.querySelectorAll('[data-blur-reveal]').forEach(el => {
      const isButton = el.tagName === 'BUTTON';
      if (!isButton) splitIntoChars(el);
      const chars = isButton ? [] : Array.from(el.querySelectorAll('.char')) as HTMLElement[];
      groups.push({ el, chars, isButton });
    });

    const portraitEl = document.querySelector('.intro__portrait') as HTMLElement;
    const contentEl  = document.querySelector('.intro__content') as HTMLElement;
    if (!contentEl) return;

    // Set initial hidden state
    groups.forEach(g => {
      if (g.isButton) {
        (g.el as HTMLElement).style.filter = 'blur(8px) brightness(0%)';
        (g.el as HTMLElement).style.opacity = '0';
      } else {
        g.chars.forEach(c => { c.style.filter = 'blur(10px) brightness(0%)'; c.style.opacity = '0'; });
      }
    });

    const charWindow = 0.2;

    // Each element uses its own rect as the scroll trigger
    // Start: element top hits 80% down the viewport
    // End: element top hits 35% down the viewport
    function getElProgress(el: Element): number {
      const rect = el.getBoundingClientRect();
      const vh = window.innerHeight;
      const startLine = vh * 0.95;
      const endLine   = vh * 0.65;
      const scrolled  = startLine - rect.top;
      return Math.min(1, Math.max(0, scrolled / (startLine - endLine)));
    }

    let ticking = false;

    function animate() {
      ticking = false;

      groups.forEach(g => {
        const rawProgress = getElProgress(g.el);

        if (g.isButton) {
          const btn = g.el as HTMLElement;
          const progress = Math.min(1, rawProgress * 2.5);
          if (progress <= 0) {
            btn.style.filter = 'blur(8px) brightness(0%)'; btn.style.opacity = '0';
          } else if (progress >= 1) {
            btn.style.filter = 'none'; btn.style.opacity = '1';
          } else {
            const blur = Math.round(8 * (1 - progress));
            const brightness = Math.round(100 * progress);
            btn.style.filter = blur > 0 ? `blur(${blur}px) brightness(${brightness}%)` : 'none';
            btn.style.opacity = Math.min(1, progress / 0.4).toFixed(2);
          }
          return;
        }

        const count = g.chars.length;
        for (let i = 0; i < count; i++) {
          const start = (i / count) * (1 - charWindow);
          const end   = start + charWindow;

          if (rawProgress <= start) {
            g.chars[i].style.filter = 'blur(10px) brightness(0%)'; g.chars[i].style.opacity = '0';
          } else if (rawProgress >= end) {
            g.chars[i].style.filter = 'none'; g.chars[i].style.opacity = '1';
          } else {
            const t = (rawProgress - start) / charWindow;
            const blur = Math.round(10 * (1 - t));
            const brightness = Math.round(100 * t);
            const opacity = Math.min(1, t / 0.4);
            g.chars[i].style.filter = blur > 0 ? `blur(${blur}px) brightness(${brightness}%)` : 'none';
            g.chars[i].style.opacity = opacity >= 1 ? '1' : opacity.toFixed(2);
          }
        }
      });

      // Portrait: shrink + round based on overall content position
      if (portraitEl) {
        const progress = getElProgress(contentEl);
        const scale  = 1 - 0.364 * progress;
        const radius = 16 + 34 * progress;
        portraitEl.style.transform = `scale(${scale.toFixed(3)})`;
        portraitEl.style.clipPath  = `inset(0% round ${Math.round(radius)}%)`;
      }
    }

    window.addEventListener('scroll', () => {
      if (!ticking) { requestAnimationFrame(animate); ticking = true; }
    }, { passive: true });

    // Set correct state on load (handles pre-scrolled pages, HMR, back-nav)
    animate();

  }); // end astro:page-load
</script>
