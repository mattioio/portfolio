---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Page Not Found — Gavin Batty" description="The page you're looking for doesn't exist." showFooter={false}>
  <section class="not-found">
    <div class="not-found__content">
      <h1>404</h1>
      <p>This page doesn't exist — but there's plenty to see.</p>
      <a href={`${base}/`} class="not-found__link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M17 17L7 7M7 7H17M7 7V17"/>
        </svg>
        Back to portfolio
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-lg);
  }

  .not-found__content {
    max-width: 480px;
  }

  .not-found h1 {
    font-family: var(--font-heading);
    font-size: clamp(6rem, 15vw, 12rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-text);
    opacity: 0.12;
    margin-bottom: var(--space-sm);
  }

  .not-found p {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-style: italic;
    color: var(--color-text);
    line-height: 1.4;
    margin-bottom: var(--space-lg);
  }

  .not-found__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 0.75rem 2rem 0.75rem calc(2rem + 0.15em);
    border: 1px solid var(--color-text);
    color: var(--color-text);
    transition: background-color 0.3s, color 0.3s;
  }

  .not-found__link:hover {
    background-color: var(--color-text);
    color: var(--color-text-light);
  }

  .not-found__link svg {
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .not-found__link:hover svg {
    transform: translate(-2px, 2px);
  }
</style>
