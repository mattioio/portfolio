---
import { CONTACT_EMAIL, CONTACT_MAILTO } from "../data/contact";
---

<footer class="footer" id="contact">
  <div class="footer__inner">

    <!-- CTA section — the conversion point -->
    <div class="footer__cta">
      <h2 class="footer__headline">Let's work together</h2>
      <p class="footer__pitch">Have a project in mind? I'd love to hear about it. Every collaboration starts with a conversation.</p>

      <div class="footer__actions">
        <a href={CONTACT_MAILTO} class="btn footer__cta-btn">
          Get in Touch
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M7 17L17 7M17 7H7M17 7V17" />
          </svg>
        </a>

        <nav class="footer__socials" aria-label="Social links">
          <a href="https://instagram.com/gavinbatty" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="https://linkedin.com/in/gavinbatty" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="https://twitter.com/gavinbatty" target="_blank" rel="noopener noreferrer" aria-label="X">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733-16zM4 20l6.768-6.768M20 4l-6.768 6.768"/></svg>
          </a>
        </nav>
      </div>
    </div>

    <!-- Info row -->
    <div class="footer__info">
      <div class="footer__brand">
        <span class="footer__name">Gavin Batty</span>
        <span class="footer__sep">/</span>
        <span class="footer__tagline">Photographer</span>
      </div>
      <p class="footer__copy">&copy; {new Date().getFullYear()} Gavin Batty. All rights reserved.</p>
    </div>

  </div>
</footer>

<style>
  .footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: -1;
    background-color: var(--color-bg-dark);
    color: var(--color-text-light);
  }

  .footer__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* ── CTA section ── */
  .footer__cta {
    text-align: center;
    padding: var(--space-xl) var(--space-md);
  }

  .footer__headline {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .footer__pitch {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.65);
    max-width: 42ch;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .footer__cta-btn {
    font-size: 0.875rem;
    padding: 0.85rem 2.5rem 0.85rem calc(2.5rem + 0.15em);
    border-color: rgba(255, 255, 255, 0.35);
  }

  .footer__cta-btn svg {
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .footer__cta-btn:hover svg {
    transform: translate(2px, -2px);
  }

  .footer__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }

  .footer__socials {
    display: flex;
    gap: 1.75rem;
  }

  .footer__socials a {
    color: rgba(255, 255, 255, 0.5);
    transition: color 0.25s, transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .footer__socials a:hover {
    color: #fff;
    transform: translateY(-2px);
  }

  /* ── Info row ── */
  .footer__info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.55);
  }

  .footer__brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer__name {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .footer__sep {
    opacity: 0.4;
  }

  .footer__tagline {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.7rem;
  }

  .footer__copy {
    font-size: 0.75rem;
  }

  @media (max-width: 768px) {
    .footer__cta {
      padding: var(--space-lg) var(--space-md);
    }

    .footer__info {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
      padding: 1.25rem var(--space-md) 1.5rem;
    }

    .footer__brand {
      justify-content: center;
    }
  }
</style>

<script>
  function syncFooterSpace() {
    const footer = document.querySelector('.footer') as HTMLElement;
    if (!footer) return;
    document.body.style.paddingBottom = footer.offsetHeight + 'px';
  }

  document.addEventListener('astro:page-load', syncFooterSpace);
  window.addEventListener('resize', syncFooterSpace);
</script>
