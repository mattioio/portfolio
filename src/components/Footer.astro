---
import { CONTACT_EMAIL, CONTACT_MAILTO } from "../data/contact";
---

<footer class="footer" id="contact">
  <div class="footer__inner">

    <!-- CTA section — the conversion point -->
    <div class="footer__cta">
      <h2 class="footer__headline">Let's work together</h2>
      <p class="footer__pitch">Have a project in mind? I'd love to hear about it. Every collaboration starts with a conversation.</p>
      <a href={CONTACT_MAILTO} class="footer__cta-btn">
        Get in Touch
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 17L17 7M17 7H7M17 7V17" />
        </svg>
      </a>
      <span class="footer__email">{CONTACT_EMAIL}</span>
    </div>

    <!-- Info row -->
    <div class="footer__info">
      <div class="footer__brand">
        <span class="footer__name">Gavin Batty</span>
        <span class="footer__sep">/</span>
        <span class="footer__tagline">Photographer</span>
      </div>

      <nav class="footer__socials" aria-label="Social links">
        <a href="https://instagram.com/gavinbatty" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://linkedin.com/in/gavinbatty" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="https://twitter.com/gavinbatty" target="_blank" rel="noopener noreferrer">X</a>
      </nav>

      <p class="footer__copy">&copy; {new Date().getFullYear()} Gavin Batty. All rights reserved.</p>
    </div>

  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-bg-dark);
    color: var(--color-text-light);
  }

  :global(.page-home) .footer {
    position: relative;
    z-index: 4;
  }

  .footer__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* ── CTA section ── */
  .footer__cta {
    text-align: center;
    padding: var(--space-xl) var(--space-md);
  }

  .footer__headline {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .footer__pitch {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.55);
    max-width: 42ch;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .footer__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 0.85rem 2.5rem 0.85rem calc(2.5rem + 0.15em);
    border: 1px solid rgba(255, 255, 255, 0.35);
    color: var(--color-text-light);
    transition: background-color 0.3s, border-color 0.3s;
  }

  .footer__cta-btn svg {
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .footer__cta-btn:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.6);
  }

  .footer__cta-btn:hover svg {
    transform: translate(2px, -2px);
  }

  .footer__email {
    display: block;
    margin-top: 1.25rem;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.05em;
  }

  /* ── Info row ── */
  .footer__info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.35);
  }

  .footer__brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer__name {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .footer__sep {
    opacity: 0.3;
  }

  .footer__tagline {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.7rem;
  }

  .footer__socials {
    display: flex;
    gap: 1.5rem;
  }

  .footer__socials a {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
    transition: color 0.2s;
  }

  .footer__socials a:hover {
    color: rgba(255, 255, 255, 0.85);
  }

  .footer__copy {
    font-size: 0.75rem;
  }

  @media (max-width: 768px) {
    .footer__cta {
      padding: var(--space-lg) var(--space-md);
    }

    .footer__info {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
      padding: 1.25rem var(--space-md) 1.5rem;
    }

    .footer__brand {
      justify-content: center;
    }

    .footer__socials {
      gap: 1.25rem;
    }
  }
</style>
