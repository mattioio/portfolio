---
import { categories } from "../data/categories";
const slides = categories;
const count = slides.length;
---

<section class="hero" data-slides={count}>
  <div class="hero__sticky">
    <!-- Full-screen slide images -->
    <div class="hero__slides">
      {slides.map((cat, i) => (
        <div
          class="hero__slide"
          data-index={i}
          data-slug={cat.slug}
        >
          <img
            src={cat.cover}
            alt={cat.name}
            loading={i < 2 ? "eager" : "lazy"}
            decoding={i === 0 ? "sync" : "async"}
          />
          <div class="hero__slide-darken"></div>
        </div>
      ))}
    </div>

    <!-- Bottom content — pagination left, text right -->
    <div class="hero__bottom">
      <!-- Pagination — vertical with progress bar -->
      <div class="hero__pagination">
        <div class="hero__page-line">
          <div class="hero__page-fill"></div>
        </div>
        <div class="hero__page-nums">
          <div class="hero__page-bubble"></div>
          {slides.map((_, i) => (
            <button
              class:list={["hero__page-num", { active: i === 0 }]}
              data-index={i}
            >
              {String(i + 1).padStart(2, "0")}
            </button>
          ))}
        </div>
      </div>

      <!-- Text: title, blurb, CTA -->
      <div class="hero__text">
        <h2 class="hero__heading">
          <span class="hero__heading-main"></span>
          <br/>
          <span class="hero__heading-accent"></span>
        </h2>
        <p class="hero__desc"></p>
        <a href="/" class="hero__enter" id="hero-enter">
          <span class="hero__enter-label">Explore</span>
          <span class="hero__enter-cat" id="hero-enter-cat"></span>
          <svg class="hero__enter-arrow" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 17L17 7M17 7H7M17 7V17"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Cursor dot — morphs to arrows at edges, eye over text -->
    <div class="hero__dot" id="hero-dot">
      <svg class="hero__dot-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M5 12L12 19M5 12L12 5"/>
      </svg>
      <svg class="hero__dot-eye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
      <span class="hero__dot-label">Click to explore</span>
    </div>

  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 600vh;
    overflow: clip;
  }

  .hero__sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    z-index: 2;
    background: var(--color-bg);
  }

  /* Full-screen slides */
  .hero__slides {
    position: absolute;
    inset: 0;
    contain: layout style;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    display: block;
    will-change: clip-path, transform, opacity;
    backface-visibility: hidden;
  }

  .hero__slide[data-index="0"] {
    opacity: 1;
  }

  .hero__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Static gradient for text legibility — always present */
  .hero__slide::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.2) 50%,
      rgba(0, 0, 0, 0.1) 100%
    );
    pointer-events: none;
  }

  /* Scroll-driven darken overlay — replaces filter:brightness()
     opacity is GPU-composited (free), brightness is CPU-repainted (expensive) */
  .hero__slide-darken {
    position: absolute;
    inset: 0;
    background: #000;
    opacity: 0;
    pointer-events: none;
    will-change: opacity;
    z-index: 1;
  }

  /* Bottom content area — pagination left, text beside it */
  .hero__bottom {
    position: absolute;
    bottom: 5vh;
    left: 3rem;
    right: 3rem;
    z-index: 10;
    display: flex;
    align-items: flex-end;
    gap: 2rem;
    color: #fff;
    pointer-events: none;
  }

  /* Text block — title, blurb, CTA */
  .hero__text {
    pointer-events: auto;
    cursor: none;
  }

  .hero__heading {
    font-family: var(--font-heading);
    font-weight: 400;
    line-height: 1.05;
    font-size: clamp(3.5rem, 9vw, 7rem);
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .hero__heading-main {
    display: inline-block;
    transition: opacity 0.3s, transform 0.4s;
  }

  .hero__heading-accent {
    display: inline-block;
    font-style: italic;
    opacity: 0.8;
    transition: opacity 0.3s, transform 0.4s;
  }

  /* Description — below title */
  .hero__desc {
    max-width: 550px;
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-style: italic;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: -0.01em;
    transition: opacity 0.3s;
  }

  /* Cursor dot — morphs to nav arrows at edges */
  .hero__dot {
    position: fixed;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #fff;
    pointer-events: none;
    z-index: 20;
    transform: translate(-50%, -50%) scale(0);
    opacity: 0;
    will-change: translate;
    mix-blend-mode: difference;
    transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                height 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                border-radius 0.3s ease,
                opacity 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    color: #000;
  }

  .hero__dot.visible {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
  }

  .hero__dot-arrow {
    width: 18px;
    height: 18px;
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
    flex-shrink: 0;
  }

  /* Arrow states */
  .hero__dot.arrow-left,
  .hero__dot.arrow-right {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    /* pointer-events stays none — clicks handled by stickyEl below */
  }

  .hero__dot.arrow-left .hero__dot-arrow,
  .hero__dot.arrow-right .hero__dot-arrow {
    opacity: 1;
  }

  .hero__dot.arrow-right .hero__dot-arrow {
    transform: rotate(180deg);
  }

  /* Eye icon — hidden by default */
  .hero__dot-eye {
    width: 20px;
    height: 20px;
    opacity: 0;
    transition: opacity 0.2s ease;
    flex-shrink: 0;
    position: absolute;
  }

  /* Eye state — over text/CTA area, matches arrow style */
  .hero__dot.eye-mode {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    /* pointer-events stays none — heroTextEl handles the click */
  }

  .hero__dot.eye-mode .hero__dot-eye {
    opacity: 1;
  }

  /* Floating label — offset below the dot */
  .hero__dot-label {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    white-space: nowrap;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-style: italic;
    color: #fff;
    opacity: 0;
    mix-blend-mode: difference;
    pointer-events: none;
    transition: opacity 0.4s ease 0.8s, transform 0.4s ease 0.8s;
    letter-spacing: 0.02em;
  }

  /* Show label only when dot is visible and in default state (not arrow) */
  .hero__dot.show-label .hero__dot-label {
    opacity: 0.7;
    transform: translateX(-50%) translateY(0);
  }

  .hero__dot.arrow-left .hero__dot-label,
  .hero__dot.arrow-right .hero__dot-label,
  .hero__dot.eye-mode .hero__dot-label {
    opacity: 0;
    transition-delay: 0s;
  }

  /* Enter Gallery — typographic link, no button chrome */
  .hero__enter {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    margin-top: 1.75rem;
    color: #fff;
    text-decoration: none;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .hero__enter.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .hero__enter-label {
    font-family: var(--font-body);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.3s;
  }

  .hero__enter-cat {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-style: italic;
    letter-spacing: -0.02em;
    position: relative;
    padding-bottom: 2px;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.4);
  }

  /* Underline always visible — clearly a link */
  .hero__enter-cat::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: rgba(255, 255, 255, 0.4);
    transition: background 0.3s ease;
  }

  .hero__enter:hover .hero__enter-cat::after {
    background: rgba(255, 255, 255, 0.8);
  }

  .hero__enter:hover .hero__enter-label {
    color: #fff;
  }

  .hero__enter-arrow {
    opacity: 0.5;
    transform: translate(0, 1px);
    transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    flex-shrink: 0;
    align-self: center;
  }

  .hero__enter:hover .hero__enter-arrow {
    opacity: 1;
    transform: translate(3px, -2px);
  }

  /* Hide default cursor over slides */
  .hero__sticky.cursor-active {
    cursor: none;
  }

  .hero__sticky.cursor-active .hero__slide {
    cursor: none;
  }

  /* Pagination — vertical */
  .hero__pagination {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 10;
    flex-shrink: 0;
    pointer-events: all;
  }

  /* Container for numbers + shared floating bubble */
  .hero__page-nums {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Single shared bubble — marks the selected slide, locked in step with scroll */
  .hero__page-bubble {
    position: absolute;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.25);
    left: 50%;
    top: 0;
    transform: translate(-50%, 0);
    /* No transition — bubble snaps immediately to the current slide */
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 0;
  }

  .hero__page-num {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.05em;
    cursor: none;
    transition: color 0.3s;
    padding: 0.6rem 0.85rem;
    position: relative;
    z-index: 1;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6);
  }

  /* Hover ring — border-only circle, scales in from centre */
  .hero__page-num::before {
    content: '';
    position: absolute;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.45);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.65);
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .hero__page-num:hover::before {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  .hero__page-num:hover {
    color: #fff;
  }

  .hero__page-num.active {
    color: #fff;
    font-weight: 500;
  }

  /* Vertical progress bar — at the top of pagination */
  .hero__page-line {
    width: 2px;
    height: 70px;
    background: rgba(255, 255, 255, 0.15);
    position: relative;
    margin-bottom: 0.25rem;
  }

  .hero__page-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    background: #fff;
    height: 0%;
    transition: height 0.3s ease;
  }


  @media (max-width: 768px) {
    .hero__bottom {
      left: 1.25rem;
      right: 1.25rem;
      bottom: 1.5rem;
      gap: 0.75rem;
      flex-direction: column;
      align-items: flex-start;
    }

    .hero__pagination {
      flex-direction: row;
      gap: 0;
      order: 2;
      margin-top: 0.75rem;
    }

    .hero__page-nums {
      flex-direction: row;
    }

    .hero__page-line {
      display: none;
    }

    .hero__page-bubble {
      left: 0;
      top: 50%;
      transform: translate(0, -50%);
    }

    .hero__heading {
      font-size: clamp(2rem, 10vw, 3.5rem);
    }

    .hero__desc {
      max-width: 280px;
      font-size: 1rem;
    }
  }
</style>

<script>
  import "../scripts/scroll-carousel";
</script>
