---
import ServicePanel from "./ServicePanel.astro";
const currentPath = Astro.url.pathname;
const isHome = currentPath === "/";
---

<header class:list={["nav", { "nav--light": isHome }]}>
  <div class="nav__inner">
    <a href="/" class="nav__logo">Gavin Batty</a>
    <button class="nav__toggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="nav__toggle-label">Hire me</span>
      <span class="nav__toggle-lines">
        <span></span>
        <span></span>
      </span>
    </button>
  </div>
</header>

<ServicePanel />

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 201; /* above panel (200) so toggle is always reachable */
    padding: 1.25rem 0;
    transition: background-color 0.3s, backdrop-filter 0.3s, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Panel open: hide the nav chrome, leave only the toggle floating as × */
  .nav.panel-open {
    background: transparent !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
  }

  .nav.panel-open .nav__logo {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }

  /* Toggle white over the dark hero image */
  .nav.panel-open .nav__toggle {
    color: #fff;
  }

  .nav--light {
    color: #fff;
  }

  .nav.scrolled {
    background-color: rgba(245, 244, 240, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: var(--color-text);
  }

  .nav__inner {
    padding: 0 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__logo {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    letter-spacing: -0.03em;
    font-weight: 400;
    font-style: italic;
  }

  .nav__toggle {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 4px;
    z-index: 1;
    color: inherit;
    position: relative;
    border: none;
    background: transparent;
    font-family: var(--font-body);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    cursor: pointer;
  }

  .nav__toggle-label {
    opacity: 0.7;
    transition: opacity 0.2s;
    translate: 0 0.15em;
  }

  .nav__toggle:hover .nav__toggle-label {
    opacity: 1;
  }

  .nav__toggle-lines {
    display: flex;
    flex-direction: column;
    gap: 6px;
    position: relative;
  }

  .nav__toggle-lines span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: currentColor;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s;
  }

  .nav__toggle[aria-expanded="true"] .nav__toggle-lines span:first-child {
    transform: translateY(3.75px) rotate(45deg);
  }

  .nav__toggle[aria-expanded="true"] .nav__toggle-lines span:last-child {
    transform: translateY(-3.75px) rotate(-45deg);
  }

  .nav__toggle[aria-expanded="true"] .nav__toggle-label {
    opacity: 0;
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .nav__inner {
      padding: 0 1.5rem;
    }
  }

</style>

<script>
  // Use an AbortController so scroll/keydown listeners are cleaned up on each navigation
  let navAC: AbortController | null = null;

  function initNav() {
    navAC?.abort();
    navAC = new AbortController();
    const { signal } = navAC;

    const nav = document.querySelector(".nav") as HTMLElement;
    const toggle = document.querySelector(".nav__toggle") as HTMLElement;
    const panel = document.getElementById("services-panel")!;

    if (!nav || !panel) return;

    // ── Reset nav state for the current page ──────────────────────────────
    const isHome = window.location.pathname === '/';
    nav.classList.remove("scrolled", "lb-hidden");
    nav.classList.toggle("nav--light", isHome);

    // ── Panel open / close ────────────────────────────────────────────────
    function openPanel() {
      const drawer = panel.querySelector(".panel__drawer") as HTMLElement | null;
      if (drawer) drawer.scrollTop = 0;

      // Set random hero background image
      const heroEl = panel.querySelector('.panel__hero') as HTMLElement | null;
      const bgEl = panel.querySelector('.panel__hero-bg') as HTMLElement | null;
      if (heroEl && bgEl) {
        try {
          const images = JSON.parse(heroEl.dataset.heroImages || '[]');
          if (images.length) {
            const img = images[Math.floor(Math.random() * images.length)];
            bgEl.style.backgroundImage = `url(${img})`;
          }
        } catch {}
      }

      panel.classList.add("active");
      panel.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      toggle?.setAttribute("aria-expanded", "true");
      nav.classList.add("panel-open");
    }

    function closePanel() {
      panel.classList.remove("active");
      panel.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      toggle?.setAttribute("aria-expanded", "false");
      nav.classList.remove("panel-open");
    }

    document.getElementById("open-services")?.addEventListener("click", openPanel, { signal });

    toggle?.addEventListener("click", () => {
      panel.classList.contains("active") ? closePanel() : openPanel();
    }, { signal });

    panel.querySelector(".panel__backdrop")?.addEventListener("click", closePanel, { signal });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && panel.classList.contains("active")) closePanel();
    }, { signal });

    // ── Scroll behaviour ──────────────────────────────────────────────────
    const hero = document.querySelector(".hero") as HTMLElement;
    const revealSection = document.querySelector(".reveal-section") as HTMLElement;

    function updateScrolled() {
      if (isHome && revealSection) {
        const card = revealSection.querySelector(".reveal-section__sticky") as HTMLElement;
        if (card) {
          nav.classList.toggle("scrolled", card.getBoundingClientRect().top <= 70);
        }
      } else {
        const threshold = hero ? hero.offsetHeight - 100 : 80;
        nav.classList.toggle("scrolled", window.scrollY > threshold);
      }
    }

    window.addEventListener("scroll", updateScrolled, { passive: true, signal });

    // Evaluate immediately so the correct state shows without needing to scroll
    updateScrolled();
  }

  // Run on every page load (initial + ClientRouter navigations)
  document.addEventListener("astro:page-load", initNav);
</script>
